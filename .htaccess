Options -Indexes

RewriteEngine On

# Pass admin and employee directories through untouched
RewriteRule ^(admin|employee)(/.*)?$ - [L]

# Force HTTPS — uncomment when SSL certificate is active
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Redirect root-level .php URLs to clean URLs (GET only, no subdirectory paths)
RewriteCond %{REQUEST_METHOD} GET
RewriteCond %{THE_REQUEST} \s/([^./]+)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Internally serve clean URLs from root-level .php files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/?]+)/?$ $1.php [L]
